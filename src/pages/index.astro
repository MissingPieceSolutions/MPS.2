---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": SITE.name,
      "url": SITE.url,
      "logo": `${SITE.url}/logo/mps-icon-512.png`,
      "description": "AI agency that designs, builds, and deploys AI systems for businesses.",
      "sameAs": []
    },
    {
      "@type": "WebSite",
      "name": SITE.name,
      "url": SITE.url
    }
  ]
};

const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<BaseLayout title={`${SITE.name} — AI Agency`} description={SITE.description} ogImage="/og/home.png">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Full-screen gate — single viewport experience, no scrolling -->
  <section id="gate" class="relative h-screen w-full overflow-hidden bg-bg-base">
    <div id="particle-canvas" class="absolute inset-0"></div>

    <!-- Real logo — crossfades in after particle convergence -->
    <img
      id="gate-logo"
      src="/logo/mps-icon-full.png"
      alt="Missing Piece Solutions logo"
      class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 md:w-64 md:h-64 lg:w-72 lg:h-72 object-contain opacity-0 transition-opacity duration-1000"
    />

    <!-- Overlay: brand name + floating navigation labels -->
    <div
      id="gate-overlay"
      class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center opacity-0 transition-opacity duration-1000"
    >
      <!-- Push content below the logo center -->
      <div class="mt-40 md:mt-52 lg:mt-56 flex flex-col items-center gap-6">
        <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-text-primary text-center tracking-tight">
          Missing Piece Solutions
        </h1>

        <!-- Floating navigation row -->
        <nav
          id="gate-nav"
          class="flex flex-wrap items-center justify-center gap-4 md:gap-8 opacity-0 transition-opacity duration-700"
        >
          {navLinks.map((link, i) => (
            <a
              href={link.href}
              class="portal-link pointer-events-auto font-mono text-xs md:text-sm uppercase tracking-widest text-text-muted hover:text-accent transition-colors duration-300"
              style={`--stagger: ${i}`}
              data-href={link.href}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </section>

  <script>
    import { initParticleGate } from '../scripts/particle-gate';

    let gate: ReturnType<typeof initParticleGate> | null = null;
    let logoTimer: ReturnType<typeof setTimeout> | null = null;
    let overlayTimer: ReturnType<typeof setTimeout> | null = null;
    let navTimer: ReturnType<typeof setTimeout> | null = null;

    function setup() {
      const container = document.getElementById('particle-canvas');
      const logo = document.getElementById('gate-logo') as HTMLImageElement | null;
      const overlay = document.getElementById('gate-overlay');
      const nav = document.getElementById('gate-nav');
      if (!container || !logo || !overlay || !nav) return;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        // Skip animation — show everything immediately
        logo.classList.remove('opacity-0');
        overlay.classList.remove('opacity-0');
        nav.classList.remove('opacity-0');
        return;
      }

      gate = initParticleGate(container);

      // Hide nav links from keyboard until visible
      nav.querySelectorAll('a').forEach(a => a.setAttribute('tabindex', '-1'));

      // After convergence (~3.2s): fade in logo, fade particles down
      logoTimer = setTimeout(() => {
        logo.classList.remove('opacity-0');
        gate?.fadeOut();
      }, 3200);

      // Show brand name slightly after logo
      overlayTimer = setTimeout(() => {
        overlay.classList.remove('opacity-0');
      }, 3600);

      // Show nav links with stagger
      navTimer = setTimeout(() => {
        nav.classList.remove('opacity-0');
        // Restore keyboard focus now that links are visible
        nav.querySelectorAll('a').forEach(a => a.removeAttribute('tabindex'));
      }, 4000);

      // Scatter on portal link click
      document.querySelectorAll('.portal-link').forEach((link) => {
        link.addEventListener('click', handlePortalClick as EventListener);
      });
    }

    async function handlePortalClick(e: MouseEvent) {
      e.preventDefault();
      const target = (e.currentTarget as HTMLAnchorElement).getAttribute('data-href');
      if (!target) return;

      // Clear pending timers immediately to avoid race conditions
      if (logoTimer) { clearTimeout(logoTimer); logoTimer = null; }
      if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
      if (navTimer) { clearTimeout(navTimer); navTimer = null; }

      if (gate) {
        await gate.scatter();
      }

      window.location.href = target;
    }

    function cleanup() {
      if (logoTimer) { clearTimeout(logoTimer); logoTimer = null; }
      if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null; }
      if (navTimer) { clearTimeout(navTimer); navTimer = null; }

      document.querySelectorAll('.portal-link').forEach((link) => {
        link.removeEventListener('click', handlePortalClick as EventListener);
      });

      if (gate) {
        gate.destroy();
        gate = null;
      }
    }

    document.addEventListener('astro:page-load', setup);
    document.addEventListener('astro:before-preparation', cleanup);
  </script>
</BaseLayout>
