---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": SITE.name,
      "url": SITE.url,
      "logo": `${SITE.url}/logo/mps-icon-512.png`,
      "description": "AI agency that designs, builds, and deploys AI systems for businesses.",
      "sameAs": []
    },
    {
      "@type": "WebSite",
      "name": SITE.name,
      "url": SITE.url
    }
  ]
};
---

<BaseLayout title={`${SITE.name} — AI Agency`} description={SITE.description} ogImage="/og/home.png">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Full-screen gate — matching slap-apps.de layout -->
  <section id="gate" class="relative h-screen w-full overflow-hidden bg-black">

    <!-- Three.js particle canvas -->
    <div id="particle-canvas" class="absolute inset-0"></div>

    <!-- Top bar: logo left, contact right -->
    <header class="absolute top-0 left-0 right-0 z-10 flex justify-between items-center px-6 py-5 md:px-10 md:py-7">
      <img
        src="/logo/mps-icon.svg"
        alt="Missing Piece Solutions"
        class="w-9 h-9 md:w-11 md:h-11"
      />
      <a
        href="/contact"
        class="font-mono text-xs md:text-sm uppercase tracking-[0.2em] text-text-primary hover:text-accent transition-colors duration-300"
      >
        Contact
      </a>
    </header>

    <!-- Gate click areas — invisible overlays positioned over canvas portals -->
    <a
      href="/experience"
      id="gate-left"
      class="gate-link absolute z-10 cursor-pointer group"
      style="top: 20%; left: 10%; width: 14%; height: 55%;"
      data-href="/experience"
    >
      <span class="sr-only">Enter experience</span>
      <!-- Hover glow hint -->
      <div class="absolute inset-0 rounded-full bg-amber-400/0 group-hover:bg-amber-400/5 transition-colors duration-500"></div>
    </a>
    <a
      href="/experience"
      id="gate-right"
      class="gate-link absolute z-10 cursor-pointer group"
      style="top: 20%; right: 10%; width: 14%; height: 55%;"
      data-href="/experience"
    >
      <span class="sr-only">Enter experience</span>
      <div class="absolute inset-0 rounded-full bg-fuchsia-400/0 group-hover:bg-fuchsia-400/5 transition-colors duration-500"></div>
    </a>

    <!-- Bottom text — matching slap-apps "WE SHAPE YOUR DREAMS!" layout -->
    <div
      id="gate-text"
      class="absolute bottom-10 md:bottom-14 left-0 right-0 z-10 text-center opacity-0 transition-opacity duration-1000"
    >
      <h1 class="text-xl md:text-2xl lg:text-3xl font-bold text-text-primary uppercase tracking-tight">
        We Build Your AI Systems!
      </h1>
      <p class="mt-2 text-text-muted text-xs md:text-sm tracking-wide">
        Click on the gates and dive in.
      </p>
    </div>
  </section>

  <script>
    import { initParticleGate } from '../scripts/particle-gate';

    let gate: Awaited<ReturnType<typeof initParticleGate>> | null = null;
    let textTimer: ReturnType<typeof setTimeout> | null = null;

    async function setup() {
      const container = document.getElementById('particle-canvas');
      const textEl = document.getElementById('gate-text');
      if (!container) return;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        // Show text immediately, skip particle animation
        if (textEl) textEl.classList.remove('opacity-0');
        return;
      }

      try {
        gate = await initParticleGate(container);
      } catch (err) {
        console.error('Particle gate failed to init:', err);
        // Show text even if particles fail
        if (textEl) textEl.classList.remove('opacity-0');
        return;
      }

      // Show bottom text after convergence (~3.5s)
      textTimer = setTimeout(() => {
        if (textEl) textEl.classList.remove('opacity-0');
      }, 3500);

      // Gate click handling — scatter particles then navigate
      document.querySelectorAll('.gate-link').forEach((link) => {
        link.addEventListener('click', handleGateClick as EventListener);
      });
    }

    async function handleGateClick(e: MouseEvent) {
      e.preventDefault();
      const target = (e.currentTarget as HTMLAnchorElement).getAttribute('data-href');
      if (!target) return;

      // Clear pending timers
      if (textTimer) { clearTimeout(textTimer); textTimer = null; }

      if (gate) {
        await gate.scatter();
      }

      window.location.href = target;
    }

    function cleanup() {
      if (textTimer) { clearTimeout(textTimer); textTimer = null; }

      document.querySelectorAll('.gate-link').forEach((link) => {
        link.removeEventListener('click', handleGateClick as EventListener);
      });

      if (gate) {
        gate.destroy();
        gate = null;
      }
    }

    document.addEventListener('astro:page-load', setup);
    document.addEventListener('astro:before-preparation', cleanup);
  </script>
</BaseLayout>
