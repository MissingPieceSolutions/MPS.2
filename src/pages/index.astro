---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="MPS — Missing Piece Solutions">
  <main class="min-h-screen flex items-center justify-center">
    <div class="text-center space-y-6 max-w-2xl px-6">
      <h1 class="text-5xl font-bold text-text-primary">
        Missing Piece Solutions
      </h1>
      <p class="text-lg text-text-muted">
        Site under construction. Something extraordinary is coming.
      </p>
      <div class="flex justify-center gap-3">
        <span class="font-mono text-xs font-medium px-2.5 py-1 rounded-full bg-accent/10 text-accent border border-accent/20">
          Astro 5
        </span>
        <span class="font-mono text-xs font-medium px-2.5 py-1 rounded-full bg-accent/10 text-accent border border-accent/20">
          Tailwind v4
        </span>
      </div>
    </div>
  </main>
</BaseLayout>
