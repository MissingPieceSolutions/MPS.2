---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';

const entry = await getEntry('pages', 'home');
const { hero, services_preview, portfolio_teaser, about_preview, cta_banner } = entry.data;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>

  <!-- 1. Hero -->
  <HeroSection
    headline={hero.headline}
    subheadline={hero.subheadline}
    ctaLabel="Get Started"
    ctaHref="#cta"
  />

  <!-- 2. Trust Bar -->
  <TrustBar />

  <!-- 3. Services Overview -->
  <section class="bg-bg-base py-24 px-6">
    <div class="max-w-6xl mx-auto space-y-12">
      <SectionHeading eyebrow="Services" heading={services_preview.heading} align="center" />
      <div class="grid md:grid-cols-3 gap-8">
        {services_preview.items.map((service: { name: string; blurb: string }) => (
          <GlassCard hover>
            <div class="space-y-4">
              <h3 class="text-lg font-semibold text-text-primary">{service.name}</h3>
              <p class="text-sm text-text-muted leading-relaxed">{service.blurb}</p>
              <Button href="/services" variant="ghost" size="sm">Learn more</Button>
            </div>
          </GlassCard>
        ))}
      </div>
    </div>
  </section>

  <!-- 4. Portfolio Teaser -->
  <section class="bg-surface py-24 px-6">
    <div class="max-w-6xl mx-auto space-y-8">
      <SectionHeading eyebrow="Portfolio" heading={portfolio_teaser.heading} />
      <div class="space-y-6">
        <Badge>{portfolio_teaser.project_name}</Badge>
        <p class="text-3xl md:text-4xl font-bold text-text-primary">
          {portfolio_teaser.outcome}
        </p>
        <p class="text-lg text-text-muted max-w-3xl leading-relaxed">
          {portfolio_teaser.teaser_text}
        </p>
        <Button href={portfolio_teaser.cta_href} variant="primary">
          {portfolio_teaser.cta_label}
        </Button>
      </div>
    </div>
  </section>

  <!-- 5. About Preview -->
  <section class="bg-bg-base py-24 px-6">
    <div class="max-w-6xl mx-auto space-y-6">
      <SectionHeading eyebrow="About" heading={about_preview.heading} />
      <p class="text-text-muted text-lg max-w-2xl leading-relaxed">
        {about_preview.text}
      </p>
      <a href={about_preview.cta_href} class="inline-block text-accent hover:underline font-medium">
        {about_preview.cta_label} &rarr;
      </a>
    </div>
  </section>

  <!-- 6. Bottom CTA -->
  <CtaBanner
    heading={cta_banner.heading}
    subtext={cta_banner.subtext}
    ctaLabel={cta_banner.cta_label}
    ctaHref={cta_banner.cta_href}
  />

</BaseLayout>
