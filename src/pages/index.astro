---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="MPS — Missing Piece Solutions">
  <!-- Hero section -->
  <section id="hero" class="min-h-screen flex items-center justify-center bg-bg-base px-6 pt-20">
    <div class="text-center space-y-6 max-w-3xl">
      <h1 class="text-5xl lg:text-7xl font-bold text-text-primary leading-tight">
        Build AI That Delivers
      </h1>
      <p class="text-lg lg:text-xl text-text-muted max-w-xl mx-auto">
        Missing Piece Solutions builds AI workflows and custom systems that turn ambitious ideas into measurable outcomes.
      </p>
      <div class="flex flex-wrap justify-center gap-4 pt-4">
        <a
          href="/services"
          class="bg-accent text-white font-semibold px-8 py-3 rounded-lg transition-all hover:shadow-[0_0_24px_rgba(139,92,246,0.4)] hover:bg-accent-muted"
        >
          Our Services
        </a>
        <a
          href="/portfolio"
          class="border border-white/20 text-text-primary font-semibold px-8 py-3 rounded-lg transition-all hover:border-white/40 hover:bg-white/5"
        >
          See Our Work
        </a>
      </div>
    </div>
  </section>

  <!-- Services section -->
  <section id="services" class="min-h-screen flex items-center justify-center bg-surface px-6 py-32">
    <div class="max-w-4xl w-full text-center space-y-12">
      <h2 class="text-4xl font-bold text-text-primary">What We Build</h2>
      <div class="grid md:grid-cols-3 gap-8 text-left">
        <div class="bg-surface-elevated rounded-xl p-8 border border-white/5 space-y-3">
          <h3 class="text-lg font-semibold text-text-primary">AI Workflow Automation</h3>
          <p class="text-sm text-text-muted">End-to-end automation of complex business processes using modern AI toolchains.</p>
        </div>
        <div class="bg-surface-elevated rounded-xl p-8 border border-white/5 space-y-3">
          <h3 class="text-lg font-semibold text-text-primary">Custom AI Development</h3>
          <p class="text-sm text-text-muted">Bespoke AI systems designed around your specific domain and data.</p>
        </div>
        <div class="bg-surface-elevated rounded-xl p-8 border border-white/5 space-y-3">
          <h3 class="text-lg font-semibold text-text-primary">AI Strategy &amp; Consulting</h3>
          <p class="text-sm text-text-muted">Clarity on where AI will move the needle — and a roadmap to get there.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio section -->
  <section id="portfolio" class="min-h-screen flex items-center justify-center bg-bg-base px-6 py-32">
    <div class="max-w-4xl w-full text-center space-y-8">
      <h2 class="text-4xl font-bold text-text-primary">Case Studies</h2>
      <p class="text-lg text-text-muted">
        Real projects. Real outcomes. Phase 5 will render full case studies here.
      </p>
      <div class="bg-surface rounded-xl p-12 border border-white/5">
        <p class="text-text-muted text-sm font-mono">[Portfolio content — Phase 5]</p>
      </div>
    </div>
  </section>

  <!-- About section -->
  <section id="about" class="min-h-screen flex items-center justify-center bg-surface px-6 py-32">
    <div class="max-w-3xl w-full text-center space-y-8">
      <h2 class="text-4xl font-bold text-text-primary">About MPS</h2>
      <p class="text-lg text-text-muted">
        A small, focused agency that builds AI systems with intent. Phase 5 will render the full team and story here.
      </p>
      <div class="bg-surface-elevated rounded-xl p-12 border border-white/5">
        <p class="text-text-muted text-sm font-mono">[About content — Phase 5]</p>
      </div>
    </div>
  </section>
</BaseLayout>
