---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "name": SITE.name,
      "url": SITE.url,
      "logo": `${SITE.url}/logo/mps-icon-512.png`,
      "description": "AI agency that designs, builds, and deploys AI systems for businesses.",
      "sameAs": []
    },
    {
      "@type": "WebSite",
      "name": SITE.name,
      "url": SITE.url
    }
  ]
};

const portalCards = [
  {
    title: 'Services',
    description: 'AI strategy, custom builds, and automation that move the needle.',
    href: '/services',
  },
  {
    title: 'Portfolio',
    description: 'Real projects, real results — see what we ship.',
    href: '/portfolio',
  },
  {
    title: 'About',
    description: 'The team and thinking behind every missing piece.',
    href: '/about',
  },
  {
    title: 'Contact',
    description: 'Ready to talk? Let\u2019s figure out your next move.',
    href: '/contact',
  },
];
---

<BaseLayout title={`${SITE.name} — AI Agency`} description={SITE.description} ogImage="/og/home.png">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- 1. Particle Gate -->
  <section id="gate" class="relative h-screen w-full overflow-hidden bg-bg-base">
    <div id="particle-canvas" class="absolute inset-0"></div>

    <!-- Overlay text — starts invisible, JS adds .is-visible after convergence -->
    <div
      id="gate-overlay"
      class="pointer-events-none absolute inset-0 flex flex-col items-center justify-center gap-6 opacity-0 transition-opacity duration-1000"
    >
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-text-primary text-center tracking-tight">
        Missing Piece Solutions
      </h1>
      <a
        href="#portal"
        class="pointer-events-auto animate-bounce text-text-muted hover:text-accent transition-colors"
        aria-label="Scroll down"
      >
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9" />
        </svg>
      </a>
    </div>
  </section>

  <!-- 2. Navigation Portal -->
  <section id="portal" class="bg-bg-base py-32 px-6">
    <div class="max-w-4xl mx-auto space-y-16 text-center">
      <div class="space-y-6">
        <h2 class="text-4xl lg:text-6xl font-bold text-text-primary" data-reveal="fade-up">
          Build AI That Delivers
        </h2>
        <p
          class="text-lg lg:text-xl text-text-muted max-w-2xl mx-auto leading-relaxed"
          data-reveal="fade-up"
          style="--reveal-delay: 120ms"
        >
          We design, build, and deploy AI systems that cut operational drag and unlock capacity your team didn't know it had.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6">
        {portalCards.map((card, i) => (
          <a
            href={card.href}
            class="group rounded-2xl bg-surface/60 backdrop-blur-md ring-1 ring-white/10 p-8 text-left transition-all duration-300 hover:-translate-y-1 hover:ring-accent/40 hover:shadow-[0_0_24px_rgba(139,92,246,0.15)]"
            data-reveal="fade-up"
            style={`--reveal-delay: ${200 + i * 100}ms`}
          >
            <h3 class="text-xl font-semibold text-text-primary mb-2 group-hover:text-accent transition-colors">
              {card.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">{card.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    import { initParticleGate } from '../scripts/particle-gate';

    let gate: ReturnType<typeof initParticleGate> | null = null;
    let overlayTimer: ReturnType<typeof setTimeout> | null = null;

    function setup() {
      const container = document.getElementById('particle-canvas');
      const overlay = document.getElementById('gate-overlay');
      if (!container || !overlay) return;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        // Skip animation — show text immediately, no Three.js
        overlay.classList.remove('opacity-0');
        return;
      }

      gate = initParticleGate(container);

      overlayTimer = setTimeout(() => {
        overlay.classList.remove('opacity-0');
      }, 3200);
    }

    function cleanup() {
      if (overlayTimer) {
        clearTimeout(overlayTimer);
        overlayTimer = null;
      }
      if (gate) {
        gate.destroy();
        gate = null;
      }
    }

    document.addEventListener('astro:page-load', setup);
    document.addEventListener('astro:before-preparation', cleanup);
  </script>
</BaseLayout>
