---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortfolioList from '../components/sections/PortfolioList.astro';
import PortfolioGrid from '../components/sections/PortfolioGrid.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';

const allStudies = await getCollection('caseStudies');

const projects = allStudies.map((study) => ({
  slug: study.id,
  title: study.data.title,
  client_display: study.data.client_display || 'Client project',
  industry: study.data.industry || 'Technology',
  services: study.data.services || [],
  outcome_headline: study.data.outcome_headline || '',
  description: study.data.summary || study.data.outcome_headline || '',
  year: '2025',
  image: '/assets/case-studies/mps-tourism/quotation-output.png',
}));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Portfolio", "item": `${SITE.url}/portfolio` }
  ]
};
---

<BaseLayout title={`Portfolio — ${SITE.name}`} description="Our work — real projects with real outcomes.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Header -->
  <section class="pt-32 pb-8 px-6">
    <div class="max-w-6xl mx-auto flex items-center justify-between flex-wrap gap-4">
      <!-- Breadcrumb -->
      <p class="font-mono text-sm text-text-muted" data-reveal="fade">
        Missing Piece Solutions / <span class="text-text-primary">Works</span>
      </p>

      <!-- View Toggle -->
      <div class="flex items-center gap-3">
        <!-- List toggle -->
        <button id="btn-list" class="text-white transition-colors duration-300" aria-label="List view">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="8" y1="6" x2="21" y2="6" />
            <line x1="8" y1="12" x2="21" y2="12" />
            <line x1="8" y1="18" x2="21" y2="18" />
            <line x1="3" y1="6" x2="3.01" y2="6" />
            <line x1="3" y1="12" x2="3.01" y2="12" />
            <line x1="3" y1="18" x2="3.01" y2="18" />
          </svg>
        </button>
        <span id="label-list" class="text-white text-xs font-mono cursor-pointer transition-colors duration-300">categorized</span>

        <span class="text-text-muted text-xs font-mono">/</span>

        <!-- Grid toggle -->
        <button id="btn-grid" class="text-text-muted transition-colors duration-300" aria-label="Grid view">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" />
            <rect x="14" y="3" width="7" height="7" />
            <rect x="3" y="14" width="7" height="7" />
            <rect x="14" y="14" width="7" height="7" />
          </svg>
        </button>
        <span id="label-grid" class="text-text-muted text-xs font-mono cursor-pointer transition-colors duration-300">freestyle</span>
      </div>
    </div>
  </section>

  <!-- List View (default) -->
  <div id="view-list" class="max-w-6xl mx-auto transition-opacity duration-500">
    <PortfolioList projects={projects} />
  </div>

  <!-- Grid View (hidden) -->
  <div id="view-grid" class="max-w-6xl mx-auto transition-opacity duration-500 hidden opacity-0">
    <PortfolioGrid projects={projects} />
  </div>

  <!-- Bottom CTA -->
  <div data-reveal="scale">
    <CtaBanner
      heading="Got a project in mind?"
      subtext="Let's talk about what AI can do for your business."
      ctaLabel="Start a Conversation"
      ctaHref="/contact"
    />
  </div>
</BaseLayout>

<script>
  import gsap from 'gsap';

  function setupViewToggle() {
    const btnList = document.getElementById('btn-list');
    const btnGrid = document.getElementById('btn-grid');
    const labelList = document.getElementById('label-list');
    const labelGrid = document.getElementById('label-grid');
    const viewList = document.getElementById('view-list');
    const viewGrid = document.getElementById('view-grid');

    if (!btnList || !btnGrid || !labelList || !labelGrid || !viewList || !viewGrid) return;

    let currentView: 'list' | 'grid' = 'list';

    function switchTo(target: 'list' | 'grid') {
      if (target === currentView) return;

      const fadeOut = target === 'grid' ? viewList : viewGrid;
      const fadeIn = target === 'grid' ? viewGrid : viewList;

      // Update active states
      const activeBtn = target === 'list' ? btnList : btnGrid;
      const inactiveBtn = target === 'list' ? btnGrid : btnList;
      const activeLabel = target === 'list' ? labelList : labelGrid;
      const inactiveLabel = target === 'list' ? labelGrid : labelList;

      activeBtn.classList.remove('text-text-muted');
      activeBtn.classList.add('text-white');
      inactiveBtn.classList.remove('text-white');
      inactiveBtn.classList.add('text-text-muted');
      activeLabel.classList.remove('text-text-muted');
      activeLabel.classList.add('text-white');
      inactiveLabel.classList.remove('text-white');
      inactiveLabel.classList.add('text-text-muted');

      // Animate transition
      gsap.to(fadeOut, {
        opacity: 0,
        duration: 0.3,
        onComplete: () => {
          fadeOut.classList.add('hidden');
          fadeIn.classList.remove('hidden');
          gsap.to(fadeIn, { opacity: 1, duration: 0.3 });
        },
      });

      currentView = target;
    }

    btnList.addEventListener('click', () => switchTo('list'));
    btnGrid.addEventListener('click', () => switchTo('grid'));
    labelList.addEventListener('click', () => switchTo('list'));
    labelGrid.addEventListener('click', () => switchTo('grid'));
  }

  document.addEventListener('astro:page-load', setupViewToggle);
</script>
