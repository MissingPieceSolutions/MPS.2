---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Experience", "item": `${SITE.url}/experience` }
  ]
};

/**
 * Sections matching slap-apps layout:
 * - Each section has a number, two headline lines (white + accent), description
 * - Sections alternate left/right alignment
 */
const sections = [
  {
    number: '001',
    line1: 'WE FIND',
    line2: 'THE PIECES',
    description: 'Every business has processes that drain time and talent. We identify exactly where AI creates real leverage — not buzzwords, not demos, real impact.',
    align: 'left' as const,
  },
  {
    number: '002',
    line1: 'WE',
    line2: 'CONNECT THEM',
    description: 'Custom AI workflows that talk to your existing tools. Automation that runs itself. Systems that turn hours of manual work into minutes.',
    align: 'right' as const,
  },
  {
    number: '003',
    line1: 'ORBIT',
    line2: 'ACHIEVED',
    description: 'Your operations running at full capacity. Your team focused on what matters. Your competitors wondering how you move so fast.',
    align: 'left' as const,
  },
];

const currentYear = new Date().getFullYear();
---

<BaseLayout
  title={`Experience — ${SITE.name}`}
  description="Discover how Missing Piece Solutions finds, connects, and launches AI systems that transform your business operations."
  ogImage="/og/experience.png"
  hideNav
  hideFooter
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Fixed full-screen canvas — Three.js particles behind all content -->
  <div id="experience-canvas" class="fixed inset-0 z-0"></div>

  <!-- Scrollable content overlay -->
  <div class="relative z-10">

    <!-- Persistent header — matching slap-apps: icon left, CONTACT right -->
    <header class="fixed top-0 left-0 right-0 z-30 flex justify-between items-center px-6 py-5 md:px-10 md:py-7">
      <a href="/">
        <img
          src="/logo/mps-icon.svg"
          alt="Missing Piece Solutions"
          class="w-9 h-9 md:w-11 md:h-11"
        />
      </a>
      <a
        href="/contact"
        class="font-mono text-xs md:text-sm uppercase tracking-[0.2em] text-text-primary hover:text-accent transition-colors duration-300"
      >
        Contact
      </a>
    </header>

    <!-- Initial spacer before first section -->
    <div class="h-[60vh]" aria-hidden="true"></div>

    <!-- Numbered sections — matching slap-apps typography treatment -->
    {sections.map((section, i) => (
      <section
        class={`min-h-screen flex items-center px-6 md:px-12 lg:px-20 ${
          section.align === 'right' ? 'justify-end' : 'justify-start'
        }`}
      >
        <div
          class={`max-w-[55%] md:max-w-[45%] ${section.align === 'right' ? 'text-right' : 'text-left'}`}
          data-reveal="fade-up"
          style={`--reveal-delay: ${i * 80}ms`}
        >
          <!-- Section number -->
          <span class="font-mono text-sm md:text-base text-accent tracking-[0.3em]">
            {section.number}
          </span>

          <!-- Headline: line 1 (white) + line 2 (accent) -->
          <h2 class="mt-3 leading-[0.85] uppercase font-bold">
            <span class="block text-[11vw] md:text-[10vw] lg:text-[9vw] text-text-primary">
              {section.line1}
            </span>
            <span class="block text-[11vw] md:text-[10vw] lg:text-[9vw] text-accent">
              {section.line2}
            </span>
          </h2>

          <!-- Description -->
          <p class={`mt-6 text-base md:text-lg text-text-muted leading-relaxed ${
            section.align === 'right' ? 'ml-auto' : ''
          } max-w-md`}>
            {section.description}
          </p>

          <!-- Scroll indicator (only on first section) -->
          {i === 0 && (
            <div class="mt-12 flex items-center gap-2 text-text-muted" data-reveal="fade" style="--reveal-delay: 400ms">
              <svg width="24" height="38" viewBox="0 0 24 38" fill="none" class="opacity-60">
                <rect x="1" y="1" width="22" height="36" rx="11" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="3" fill="currentColor" class="animate-bounce"/>
              </svg>
            </div>
          )}
        </div>
      </section>
    ))}

    <!-- Giant viewport-filling brand text — matching slap-apps "SLAP APPS" section -->
    <section class="min-h-screen flex items-center justify-center px-4 overflow-hidden">
      <h2
        class="text-[14vw] md:text-[13vw] lg:text-[12vw] font-bold uppercase text-text-primary leading-[0.85] text-center tracking-tighter whitespace-nowrap"
        data-reveal="scale"
      >
        <span>MISSING</span>
        <br />
        <!-- "PIECE" gets the glow effect like slap-apps' glowing "A" -->
        <span class="relative inline-block">
          <span class="relative z-10">PIECE</span>
          <span
            class="absolute inset-0 text-white blur-[40px] opacity-30 pointer-events-none select-none z-0"
            aria-hidden="true"
          >PIECE</span>
        </span>
        <br />
        <span>SOLUTIONS</span>
      </h2>
    </section>

    <!-- Footer — matching slap-apps footer structure -->
    <footer class="pb-16 pt-8 px-6 text-center">
      <!-- Tagline -->
      <p class="text-base md:text-lg font-bold text-text-primary">
        Where AI systems really work!
      </p>
      <!-- Copyright -->
      <p class="mt-3 text-sm text-text-muted">
        &copy; {currentYear} {SITE.name} | Built with precision.
      </p>
      <!-- Footer nav links -->
      <nav class="mt-8 flex flex-wrap justify-center gap-8 md:gap-12" aria-label="Footer navigation">
        <a href="/services" class="text-sm text-text-muted hover:text-text-primary transition-colors">Services</a>
        <a href="/pricing" class="text-sm text-text-muted hover:text-text-primary transition-colors">Pricing</a>
        <a href="/portfolio" class="text-sm text-text-muted hover:text-text-primary transition-colors">Portfolio</a>
        <a href="/about" class="text-sm text-text-muted hover:text-text-primary transition-colors">About</a>
        <a href="/contact" class="text-sm text-text-muted hover:text-text-primary transition-colors">Contact</a>
        <a href="/privacy" class="text-sm text-text-muted hover:text-text-primary transition-colors">Privacy</a>
      </nav>
    </footer>
  </div>

  <!-- Fixed counters — bottom-right, matching slap-apps ALTITUDE/VELOCITY style -->
  <div id="experience-counters" class="fixed bottom-6 right-6 md:bottom-8 md:right-10 z-20 font-mono pointer-events-none text-right space-y-3">
    <div>
      <div class="text-3xl md:text-4xl font-bold text-text-primary tabular-nums" id="counter-altitude">0</div>
      <span class="uppercase tracking-[0.2em] text-[10px] md:text-xs text-text-muted">Altitude</span>
    </div>
    <div>
      <div class="text-3xl md:text-4xl font-bold text-text-primary tabular-nums" id="counter-velocity">0</div>
      <span class="uppercase tracking-[0.2em] text-[10px] md:text-xs text-text-muted">Velocity</span>
    </div>
  </div>

  <script>
    import { initParticleExperience } from '../scripts/particle-experience';

    let experience: ReturnType<typeof initParticleExperience> | null = null;
    let counterRAF = 0;

    function setup() {
      const container = document.getElementById('experience-canvas');
      const altitudeEl = document.getElementById('counter-altitude');
      const velocityEl = document.getElementById('counter-velocity');
      const countersEl = document.getElementById('experience-counters');
      if (!container) return;

      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (prefersReduced) {
        container.style.display = 'none';
        if (countersEl) countersEl.style.display = 'none';
        return;
      }

      experience = initParticleExperience(container);

      // Counter updates — matching slap-apps altitude/velocity counters
      let lastScroll = 0;
      let smoothVelocity = 0;

      function updateCounters() {
        counterRAF = requestAnimationFrame(updateCounters);

        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const progress = maxScroll > 0 ? window.scrollY / maxScroll : 0;

        // Altitude: scales from 0 to ~350 (matching slap-apps range)
        const altitude = Math.round(progress * 349);

        // Velocity: change in scroll per frame, scaled up
        const rawVelocity = Math.abs(progress - lastScroll) * 1000;
        smoothVelocity += (rawVelocity - smoothVelocity) * 0.1;
        lastScroll = progress;

        if (altitudeEl) altitudeEl.textContent = altitude.toString();
        if (velocityEl) velocityEl.textContent = Math.round(smoothVelocity).toString();
      }

      updateCounters();
    }

    function cleanup() {
      cancelAnimationFrame(counterRAF);
      if (experience) {
        experience.destroy();
        experience = null;
      }
    }

    document.addEventListener('astro:page-load', setup);
    document.addEventListener('astro:before-preparation', cleanup);
  </script>
</BaseLayout>
