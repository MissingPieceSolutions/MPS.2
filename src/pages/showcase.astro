---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import GlassCard from '../components/ui/GlassCard.astro';
---

<BaseLayout title="Component Showcase — MPS" description="UI component library for Missing Piece Solutions">
  <main class="min-h-screen bg-bg-base px-6 py-16 space-y-24 max-w-5xl mx-auto">

    <!-- Buttons -->
    <section>
      <SectionHeading
        eyebrow="Primitives"
        heading="Buttons"
        subheading="Primary and ghost variants with hover states and motion-safe scale."
        class="mb-10"
      />
      <div class="flex flex-wrap items-center gap-4">
        <Button>Get Started</Button>
        <Button variant="ghost">Learn More</Button>
        <Button size="sm">Small</Button>
        <Button variant="ghost" size="sm">Small Ghost</Button>
        <Button href="/contact">Contact Us</Button>
        <Button href="/showcase" variant="ghost">Link Ghost</Button>
      </div>
    </section>

    <!-- Badges -->
    <section>
      <SectionHeading
        eyebrow="Primitives"
        heading="Badges"
        subheading="Accent and muted variants using font-mono for a technical feel."
        class="mb-10"
      />
      <div class="flex flex-wrap items-center gap-3">
        <Badge>AI Powered</Badge>
        <Badge>Astro 5</Badge>
        <Badge>Tailwind v4</Badge>
        <Badge variant="muted">Coming Soon</Badge>
        <Badge variant="muted">In Progress</Badge>
      </div>
    </section>

    <!-- Section Headings -->
    <section>
      <SectionHeading
        eyebrow="Primitives"
        heading="Section Headings"
        subheading="Eyebrow + heading + optional subheading pattern. Supports left and center alignment."
        class="mb-10"
      />
      <div class="space-y-12">
        <div class="bg-surface/40 rounded-xl p-8">
          <p class="text-xs text-text-muted font-mono mb-6 uppercase tracking-widest">Left aligned (default)</p>
          <SectionHeading
            eyebrow="Our Services"
            heading="What We Build"
            subheading="AI systems that actually deliver results."
          />
        </div>
        <div class="bg-surface/40 rounded-xl p-8">
          <p class="text-xs text-text-muted font-mono mb-6 uppercase tracking-widest text-center">Center aligned</p>
          <SectionHeading
            eyebrow="Portfolio"
            heading="Our Work"
            subheading="Outcome-first case studies from real client engagements."
            align="center"
          />
        </div>
        <div class="bg-surface/40 rounded-xl p-8">
          <p class="text-xs text-text-muted font-mono mb-6 uppercase tracking-widest">Without subheading</p>
          <SectionHeading
            eyebrow="About"
            heading="Who We Are"
          />
        </div>
      </div>
    </section>

    <!-- Glass Cards -->
    <section>
      <SectionHeading
        eyebrow="Primitives"
        heading="Glass Cards"
        subheading="Semi-transparent background with backdrop blur and subtle ring edge. Hover variant adds lift."
        class="mb-10"
      />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <GlassCard>
          <div class="space-y-3">
            <Badge>AI Workflow</Badge>
            <h3 class="text-lg font-semibold text-text-primary">Standard Card</h3>
            <p class="text-text-muted text-sm">
              Glass morphism with backdrop blur, semi-transparent surface, and subtle ring border.
            </p>
          </div>
        </GlassCard>
        <GlassCard hover>
          <div class="space-y-3">
            <Badge variant="muted">Hoverable</Badge>
            <h3 class="text-lg font-semibold text-text-primary">Hover Card</h3>
            <p class="text-text-muted text-sm">
              Adds scale transform and accent ring glow on hover. Uses motion-safe for accessibility.
            </p>
          </div>
        </GlassCard>
        <GlassCard hover>
          <div class="space-y-3">
            <Badge>Custom AI</Badge>
            <h3 class="text-lg font-semibold text-text-primary">Project Card</h3>
            <p class="text-text-muted text-sm">
              Cards are composable — accepts any slot content including Badges, headings, and CTAs.
            </p>
            <Button size="sm" variant="ghost" href="/showcase">View Case Study</Button>
          </div>
        </GlassCard>
      </div>
    </section>

    <!-- Combined usage -->
    <section>
      <SectionHeading
        eyebrow="Composition"
        heading="Components Together"
        subheading="All four primitives working together as they will in Phase 5 page sections."
        align="center"
        class="mb-10"
      />
      <GlassCard class="max-w-2xl mx-auto">
        <div class="space-y-6 text-center">
          <div class="flex justify-center gap-2">
            <Badge>AI Strategy</Badge>
            <Badge variant="muted">Case Study</Badge>
          </div>
          <SectionHeading
            eyebrow="Phase 5 Preview"
            heading="Build AI That Delivers"
            subheading="Every service we offer maps to measurable business outcomes."
            align="center"
          />
          <div class="flex justify-center gap-4">
            <Button>Get Started</Button>
            <Button variant="ghost">See Our Work</Button>
          </div>
        </div>
      </GlassCard>
    </section>

  </main>
</BaseLayout>
