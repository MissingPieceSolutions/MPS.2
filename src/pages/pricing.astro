---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import GlassCard from '../components/ui/GlassCard.astro';
import Badge from '../components/ui/Badge.astro';
import Button from '../components/ui/Button.astro';
import CtaBanner from '../components/sections/CtaBanner.astro';
import { SITE } from '../config';

const entry = await getEntry('pages', 'pricing');
if (!entry) throw new Error('Pricing page content not found');
const { title, description, hero, how_it_works, products, products_section, custom_pricing, cta } = entry.data;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Pricing", "item": `${SITE.url}/pricing` }
  ]
};
---

<BaseLayout title={title} description={description} ogImage="/og/pricing.png">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- Hero -->
  <section class="bg-bg-base py-24 px-6" data-reveal="fade">
    <div class="max-w-4xl mx-auto text-center">
      <SectionHeading
        eyebrow="Pricing"
        heading={hero.heading}
        subheading={hero.subheading}
        align="center"
      />
    </div>
  </section>

  <!-- Product Pricing Cards -->
  <section class="bg-surface py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <SectionHeading
        eyebrow="Performance-Based"
        heading={products_section.heading}
        subheading={products_section.subheading}
        align="center"
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-16">
        {products.map((product: any, i: number) => (
          <div data-reveal="fade-up" style={`--reveal-delay: ${i * 100}ms`}>
            <GlassCard hover>
              <div class="flex flex-col h-full space-y-3">
                <h3 class="text-lg font-semibold text-text-primary">{product.name}</h3>
                <div class="space-y-1">
                  <p class="text-2xl font-bold text-accent">{product.price}</p>
                  <p class="text-xs text-text-muted">{product.metric}</p>
                </div>
                <div class="pt-3 border-t border-white/5">
                  <p class="text-xs text-text-muted">
                    Or flat retainer: <span class="text-text-primary">{product.retainer_alt}</span>
                  </p>
                </div>
              </div>
            </GlassCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="bg-bg-base py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeading
        eyebrow="Process"
        heading={how_it_works.heading}
        align="center"
      />

      <div class="grid md:grid-cols-2 gap-8 mt-16">
        {how_it_works.steps.map((step: any, i: number) => (
          <div class="flex gap-4" data-reveal="fade-up" style={`--reveal-delay: ${i * 100}ms`}>
            <span class="text-3xl font-bold text-accent/30 font-mono shrink-0">{step.number}</span>
            <div>
              <h3 class="text-base font-semibold text-text-primary">{step.title}</h3>
              <p class="text-sm text-text-muted mt-1">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Custom & Retainer -->
  <section class="bg-surface py-24 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeading
        eyebrow="Enterprise"
        heading={custom_pricing.heading}
        align="center"
      />

      <div class="grid md:grid-cols-2 gap-8 mt-12">
        {custom_pricing.items.map((item: any, i: number) => (
          <div data-reveal="fade-up" style={`--reveal-delay: ${i * 120}ms`}>
            <GlassCard>
              <div class="space-y-3">
                <h3 class="text-lg font-semibold text-text-primary">{item.name}</h3>
                <p class="text-sm text-text-muted">{item.description}</p>
                <p class="text-xl font-bold text-accent">{item.price}</p>
                <Button href="/contact" variant="ghost" size="sm">
                  Let's talk
                </Button>
              </div>
            </GlassCard>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <CtaBanner
    heading={cta.heading}
    subtext={cta.text}
    ctaLabel={cta.label}
    ctaHref={cta.href}
  />
</BaseLayout>
