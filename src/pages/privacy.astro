---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE.url },
    { "@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": `${SITE.url}/privacy` }
  ]
};
---

<BaseLayout
  title="Privacy Policy — Missing Piece Solutions"
  description="How Missing Piece Solutions handles your data."
  ogImage="/og/privacy.png"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <section class="bg-bg-base py-24 px-6">
    <div class="max-w-3xl mx-auto prose prose-invert">
      <h1>Privacy Policy</h1>
      <p><strong>Last updated: March 2026</strong></p>

      <h2>Introduction</h2>
      <p>
        Missing Piece Solutions ("MPS", "we", "us") operates the website at missingpiecesolutions.com.
        This policy explains what personal data we collect, how we use it, and your rights.
      </p>
      <p>
        This is a simple website. We don't run an e-commerce store, we don't serve ads, and we don't
        track you across the web. The only personal data we collect is what you choose to send us
        through the contact form.
      </p>

      <hr />

      <h2>What We Collect</h2>
      <p>When you submit the contact form, we collect:</p>
      <ul>
        <li><strong>Your name</strong> — so we know who we're talking to</li>
        <li><strong>Your email address</strong> — so we can reply</li>
        <li><strong>Your company or organisation</strong> (optional) — to understand your context</li>
        <li><strong>Your message</strong> — what you've told us about your project or enquiry</li>
      </ul>
      <p>
        We do not collect payment information, create user accounts, or gather any data beyond what
        you voluntarily submit.
      </p>

      <hr />

      <h2>How We Use Your Data</h2>
      <p>We use your contact form submission for one purpose only: to respond to your enquiry.</p>
      <p>We will not:</p>
      <ul>
        <li>Add you to a mailing list without your explicit consent</li>
        <li>Share your details with third parties for marketing</li>
        <li>Use your data for automated decision-making or profiling</li>
      </ul>

      <hr />

      <h2>Third-Party Services</h2>
      <p>Two third-party services process data on our behalf:</p>
      <p>
        <strong>Formspree</strong> handles contact form submissions. When you submit the form, your
        data is transmitted to Formspree's servers and forwarded to us by email. Formspree's privacy
        policy is available at{' '}
        <a href="https://formspree.io/legal/privacy-policy/" class="text-accent hover:underline">
          formspree.io/legal/privacy-policy
        </a>.
      </p>
      <p>
        <strong>Cloudflare</strong> hosts this website. Cloudflare may process network metadata (such
        as IP addresses) as part of its infrastructure and security services. Cloudflare's privacy
        policy is available at{' '}
        <a href="https://www.cloudflare.com/privacypolicy/" class="text-accent hover:underline">
          cloudflare.com/privacypolicy
        </a>.
      </p>
      <p>No other third-party services receive your personal data.</p>

      <hr />

      <h2>Data Retention</h2>
      <p>
        Form submissions are retained in Formspree until we manually delete them. There is no
        automated retention period. If you'd like your submission deleted, contact us at the address
        below.
      </p>

      <hr />

      <h2>Your Rights</h2>
      <p>You have the right to:</p>
      <ul>
        <li><strong>Request access</strong> to any personal data we hold about you</li>
        <li><strong>Request deletion</strong> of your data</li>
      </ul>
      <p>
        To exercise either right, email us at{' '}
        <a href="mailto:privacy@missingpiecesolutions.com" class="text-accent hover:underline">
          privacy@missingpiecesolutions.com
        </a>. We'll respond within a reasonable timeframe.
      </p>

      <hr />

      <h2>Cookies</h2>
      <p>This website does not use cookies for tracking, analytics, or advertising.</p>
      <p>
        Cloudflare may set essential security cookies as part of its infrastructure services. These
        are not used to track your behaviour across sites.
      </p>

      <hr />

      <h2>Changes to This Policy</h2>
      <p>
        We may update this policy from time to time. The "Last updated" date at the top of this page
        reflects when changes were last made. Continued use of the site after any changes constitutes
        acceptance of the updated policy.
      </p>

      <hr />

      <h2>Contact</h2>
      <p>
        For privacy-related questions or data requests, email:{' '}
        <a href="mailto:privacy@missingpiecesolutions.com" class="text-accent hover:underline">
          <strong>privacy@missingpiecesolutions.com</strong>
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
