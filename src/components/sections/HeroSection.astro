---
import Button from '../ui/Button.astro';

interface Props {
  headline: string;
  subheadline: string;
  ctaLabel: string;
  ctaHref: string;
}

const { headline, subheadline, ctaLabel, ctaHref } = Astro.props;
---

<section class="relative min-h-0 md:min-h-dvh flex items-center justify-center bg-bg-base px-6 pt-20 pb-16 md:pb-0 overflow-hidden">
  <!-- Energy ring backdrop -->
  <img
    src="/logo-energy-ring.png"
    alt=""
    aria-hidden="true"
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] md:w-[800px] opacity-20 pointer-events-none select-none"
  />

  <!-- Content -->
  <div class="relative z-10 text-center space-y-6 max-w-3xl">
    <h1 class="text-5xl lg:text-7xl font-bold text-text-primary leading-tight">
      {headline}
    </h1>
    <p class="text-lg lg:text-xl text-text-muted max-w-xl mx-auto">
      {subheadline}
    </p>
    <div class="pt-4">
      <Button href={ctaHref} variant="primary">
        {ctaLabel}
      </Button>
    </div>
  </div>
</section>
