---
interface Props {
  name: string;
  role: string;
  bio: string;
  linkedin: string;
  initials: string;
  photo?: string | null;
}

const { name, role, bio, linkedin, initials, photo } = Astro.props;
---

<div class="group flex flex-col items-center text-center space-y-4 transition-all duration-300 motion-safe:hover:-translate-y-1">
  <!-- Avatar -->
  {photo ? (
    <img
      src={photo}
      alt={name}
      class="w-20 h-20 rounded-full object-cover ring-2 ring-accent/40 transition-shadow duration-300 group-hover:shadow-[0_0_20px_rgba(139,92,246,0.2)]"
    />
  ) : (
    <div class="w-20 h-20 rounded-full bg-accent/20 ring-2 ring-accent/40 flex items-center justify-center transition-shadow duration-300 group-hover:shadow-[0_0_20px_rgba(139,92,246,0.2)]">
      <span class="text-xl font-bold text-accent">{initials}</span>
    </div>
  )}

  <!-- Info -->
  <h3 class="text-lg font-semibold text-text-primary">{name}</h3>
  <p class="text-sm text-accent">{role}</p>
  <p class="text-sm text-text-muted max-w-xs">{bio}</p>

  <!-- LinkedIn -->
  <a
    href={linkedin}
    target="_blank"
    rel="noopener noreferrer"
    class="text-xs text-text-muted hover:text-accent transition-colors"
  >
    LinkedIn &rarr;
  </a>
</div>
