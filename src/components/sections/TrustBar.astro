---
const techStack = [
  'OpenAI',
  'Anthropic',
  'Gemini',
  'n8n',
  'Zapier',
  'Make',
  'Python',
  'TypeScript',
  'Supabase',
  'Cloudflare',
];
---

<section class="bg-surface py-6 px-6" data-reveal="fade">
  <div class="max-w-6xl mx-auto overflow-x-auto">
    <div class="flex items-center justify-center gap-6 whitespace-nowrap">
      {techStack.map((name, i) => (
        <span class="text-accent/70 text-xs font-mono tracking-wider uppercase select-none">
          {name}
        </span>
      ))}
    </div>
  </div>
</section>
