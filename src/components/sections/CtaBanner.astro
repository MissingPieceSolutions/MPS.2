---
import Button from '../ui/Button.astro';

interface Props {
  heading: string;
  subtext: string;
  ctaLabel: string;
  ctaHref: string;
}

const { heading, subtext, ctaLabel, ctaHref } = Astro.props;
---

<section id="cta" class="bg-accent/10 py-20 px-6" data-reveal="scale">
  <div class="max-w-3xl mx-auto text-center space-y-6">
    <h2 class="text-3xl md:text-4xl font-bold text-text-primary">
      {heading}
    </h2>
    <p class="text-lg text-text-muted">
      {subtext}
    </p>
    <div class="pt-2">
      <Button href={ctaHref} variant="primary">
        {ctaLabel}
      </Button>
    </div>
  </div>
</section>
