---
interface Project {
  slug: string;
  title: string;
  client_display: string;
  industry: string;
  services: string[];
  outcome_headline: string;
  description: string;
  year: string;
  image?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<!-- Backdrop blur overlay — activates when any card is hovered -->
<div
  id="grid-backdrop"
  class="fixed inset-0 backdrop-blur-[5px] bg-black/40 z-40 pointer-events-none opacity-0 transition-opacity duration-300"
  aria-hidden="true"
></div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 px-6 py-8">
  {projects.map((project) => (
    <a
      href={`/portfolio/${project.slug}`}
      class="portfolio-grid-card group relative aspect-[4/3] rounded-2xl overflow-hidden ring-1 ring-white/10 z-[45] block"
      style={
        project.image
          ? `background-image: url(${project.image}); background-size: cover; background-position: center;`
          : 'background: linear-gradient(135deg, var(--color-surface), var(--color-surface-elevated));'
      }
    >
      {/* Dark overlay on hover */}
      <div class="absolute inset-0 bg-black/0 group-hover:bg-black/40 transition-colors duration-300" />

      {/* Bottom gradient for text readability */}
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/70 to-transparent" />

      {/* Minimal label at bottom */}
      <div class="absolute inset-x-0 bottom-0 p-4 flex items-end gap-2">
        <span class="font-mono text-xs text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          {project.year}
        </span>
        <span class="text-text-primary font-medium text-sm leading-tight">
          {project.title}
        </span>
      </div>

      {/* Glassmorphic tooltip — desktop only */}
      <div
        class="hidden lg:block absolute left-[calc(100%+16px)] top-1/2 -translate-y-1/2 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 will-change-transform"
      >
        {/* Gradient border wrapper */}
        <div class="p-[1px] bg-gradient-to-b from-white/10 to-white/20 rounded-[24px]">
          <div class="bg-bg-base w-[350px] p-6 rounded-[23px]">
            <h3 class="text-text-primary font-bold text-base mb-2">
              {project.title}
            </h3>
            <p class="text-text-muted text-sm leading-relaxed mb-4">
              {project.description}
            </p>
            {project.services.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {project.services.map((service) => (
                  <span class="inline-flex font-mono text-xs font-medium px-2.5 py-1 rounded-full ring-1 ring-white/10 text-text-muted">
                    {service}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </a>
  ))}
</div>

<script>
  function initPortfolioGrid() {
    const cards = document.querySelectorAll('.portfolio-grid-card');
    const backdrop = document.getElementById('grid-backdrop');

    if (!backdrop || cards.length === 0) return;

    cards.forEach((card) => {
      card.addEventListener('mouseenter', () => {
        backdrop.style.opacity = '1';
      });

      card.addEventListener('mouseleave', () => {
        backdrop.style.opacity = '0';
      });
    });
  }

  document.addEventListener('astro:page-load', initPortfolioGrid);
</script>
