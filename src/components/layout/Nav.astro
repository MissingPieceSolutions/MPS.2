---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'About', href: '/about' },
];

const pathname = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-bg-base/80 backdrop-blur-md transition-transform duration-300"
  aria-label="Main navigation"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="MPS — Missing Piece Solutions">
      <img src="/logo/mps-logo.svg" alt="MPS — Missing Piece Solutions" class="h-8 w-auto" />
    </a>

    <!-- Desktop nav links -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Site navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm font-medium transition-colors ${
            isActive(link.href)
              ? 'text-text-primary'
              : 'text-text-muted hover:text-text-primary'
          }`}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA + hamburger -->
    <div class="flex items-center gap-4">
      <!-- Contact CTA (desktop) -->
      <a
        href="/contact"
        class="hidden lg:inline-flex items-center bg-accent text-white text-sm font-medium px-5 py-2 rounded-lg transition-all hover:shadow-[0_0_20px_rgba(139,92,246,0.4)] hover:bg-accent-muted"
      >
        Contact
      </a>

      <!-- Hamburger button (mobile) -->
      <button
        id="hamburger-btn"
        type="button"
        class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-md transition-colors hover:bg-white/5"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-bar block w-5 h-0.5 bg-text-primary rounded-full transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-text-primary rounded-full transition-all duration-300"></span>
        <span class="hamburger-bar block w-5 h-0.5 bg-text-primary rounded-full transition-all duration-300"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile overlay menu -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[100] bg-bg-base/95 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-label="Mobile navigation menu"
>
  <!-- Close button -->
  <button
    id="mobile-close-btn"
    type="button"
    class="absolute top-5 right-6 w-10 h-10 flex items-center justify-center rounded-md text-text-muted hover:text-text-primary hover:bg-white/5 transition-colors"
    aria-label="Close menu"
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Menu content -->
  <div class="flex flex-col items-center justify-center h-full gap-10 px-6">
    {navLinks.map((link, i) => (
      <a
        href={link.href}
        class="mobile-link text-3xl font-semibold text-text-primary opacity-0 translate-y-4 transition-all duration-300 hover:text-accent"
        style={`transition-delay: ${i * 60}ms`}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))}
    <a
      href="/contact"
      class="mobile-link mt-2 bg-accent text-white text-lg font-semibold px-8 py-3 rounded-lg opacity-0 translate-y-4 transition-all duration-300 hover:shadow-[0_0_24px_rgba(139,92,246,0.5)] hover:bg-accent-muted"
      style={`transition-delay: ${navLinks.length * 60}ms`}
    >
      Contact
    </a>
  </div>
</div>

<script>
  function initNav() {
    const nav = document.getElementById('main-nav');
    const hamburger = document.getElementById('hamburger-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const closeBtn = document.getElementById('mobile-close-btn');
    const mobileLinks = document.querySelectorAll('#mobile-menu a');

    if (!nav || !hamburger || !mobileMenu || !closeBtn) return;

    // ── Hide-on-scroll-down / show-on-scroll-up ──────────────────────────────
    let lastScrollY = window.scrollY;
    let ticking = false;
    const SCROLL_THRESHOLD = 80;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function handleScroll() {
      const currentY = window.scrollY;

      if (!prefersReducedMotion) {
        if (currentY > SCROLL_THRESHOLD && currentY > lastScrollY) {
          nav.classList.add('-translate-y-full');
        } else {
          nav.classList.remove('-translate-y-full');
        }
      } else {
        // Reduced motion: simple opacity instead of translate
        if (currentY > SCROLL_THRESHOLD && currentY > lastScrollY) {
          nav.style.opacity = '0';
          nav.style.pointerEvents = 'none';
        } else {
          nav.style.opacity = '1';
          nav.style.pointerEvents = '';
        }
      }

      lastScrollY = currentY;
      ticking = false;
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(handleScroll);
        ticking = true;
      }
    }, { passive: true });

    // ── Mobile menu open ─────────────────────────────────────────────────────
    function openMenu() {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto');
      mobileMenu.setAttribute('aria-hidden', 'false');
      hamburger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';

      // Animate links in
      document.querySelectorAll('#mobile-menu .mobile-link').forEach(link => {
        (link as HTMLElement).style.opacity = '1';
        (link as HTMLElement).style.transform = 'translateY(0)';
      });
    }

    function closeMenu() {
      document.querySelectorAll('#mobile-menu .mobile-link').forEach(link => {
        (link as HTMLElement).style.opacity = '';
        (link as HTMLElement).style.transform = '';
      });

      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');
      mobileMenu.setAttribute('aria-hidden', 'true');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    hamburger.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);

    // Close on link click
    mobileLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && hamburger.getAttribute('aria-expanded') === 'true') {
        closeMenu();
      }
    });
  }

  // Run on initial page load
  document.addEventListener('DOMContentLoaded', initNav);
  // Re-run after Astro View Transitions navigation (if ClientRouter is added later)
  document.addEventListener('astro:page-load', initNav);
</script>
