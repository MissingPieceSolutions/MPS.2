---
interface Props {
  variant?: 'accent' | 'muted';
  class?: string;
}

const { variant = 'accent', class: className } = Astro.props;

const base = 'inline-flex font-mono text-xs font-medium px-2.5 py-1 rounded-full';

const variants = {
  accent: 'bg-accent/10 text-accent border border-accent/20',
  muted: 'bg-surface-elevated text-text-muted border border-border-default/20',
};

const classes = [base, variants[variant], className].filter(Boolean).join(' ');
---

<span class={classes}>
  <slot />
</span>
