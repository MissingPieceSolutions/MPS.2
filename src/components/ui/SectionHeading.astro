---
interface Props {
  eyebrow: string;
  heading: string;
  subheading?: string;
  align?: 'left' | 'center';
  class?: string;
}

const { eyebrow, heading, subheading, align = 'left', class: className } = Astro.props;

const isCenter = align === 'center';
const wrapperClass = [isCenter ? 'text-center' : '', className].filter(Boolean).join(' ');
const subheadingClass = [
  'mt-4 text-lg text-text-muted max-w-2xl',
  isCenter ? 'mx-auto' : '',
]
  .filter(Boolean)
  .join(' ');
---

<div class={wrapperClass || undefined}>
  <p class="text-xs font-semibold tracking-widest uppercase text-accent mb-3">
    {eyebrow}
  </p>
  <h2 class="text-3xl md:text-4xl font-bold text-text-primary leading-tight">
    {heading}
  </h2>
  {subheading && (
    <p class={subheadingClass}>
      {subheading}
    </p>
  )}
</div>
